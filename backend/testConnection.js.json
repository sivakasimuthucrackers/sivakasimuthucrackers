import { MongoClient } from "mongodb";
import dotenv from "dotenv";

dotenv.config();

async function test() {
  try {
    const client = new MongoClient(process.env.MONGO_URI);

    await client.connect();

    console.log("✅ MongoDB Connected Successfully");

    await client.close();
  } catch (err) {
    console.log(err);
  }
}

test();